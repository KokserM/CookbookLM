{
  "manifest_version": 3,
  "name": "CookbookLM",
  "description": "Extract recipes, reason safe allergen-aware substitutions with your OpenAI key, and generate printable PDFs.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CookbookLM",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting", "downloads", "offscreen", "sidePanel", "notifications"],
  "host_permissions": ["<all_urls>"]
}
